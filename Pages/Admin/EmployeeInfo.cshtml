@page
@using AttendanceSystem.Models.Enums
@model AttendanceSystem.Pages.Admin.EmployeeInfoModel
@{
    ViewData["Title"] = "员工信息";
    var e = Model.Employee;
}

<style>
    /* 打印时只保留资料本身，左侧切换栏和顶部按钮不打印 */
    @@media print {
        .no-print { display: none !important; }
        .card { border: 1px solid #ccc !important; box-shadow: none !important; break-inside: avoid; }
    }
</style>

<div class="page-header d-flex justify-content-between align-items-center no-print">
    <h4><i class="bi bi-person-vcard me-2 text-primary"></i>员工信息</h4>
    <div class="d-flex gap-2">
        <a href="/Admin/UserManage" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>返回员工管理</a>
        @if (e is not null)
        {
            <button class="btn btn-outline-primary btn-sm" onclick="window.print()"><i class="bi bi-printer me-1"></i>打印</button>
        }
    </div>
</div>

<div class="d-flex gap-3 align-items-start">

    <!-- ── 左侧：切换员工 ──────────────────────────────────────────────── -->
    <div class="card no-print" style="width:260px;flex-shrink:0">
        <div class="card-header py-2"><i class="bi bi-search me-1"></i>切换员工</div>
        <div class="p-2">
            <form method="get" class="d-flex gap-1">
                <input type="text" name="keyword" value="@Model.Keyword" class="form-control form-control-sm"
                       placeholder="姓名 / 工号" />
                <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search"></i></button>
            </form>
        </div>
        <div class="list-group list-group-flush" style="max-height:65vh;overflow:auto">
            @if (!Model.QuickList.Any())
            {
                <div class="text-muted small p-3">没有匹配的员工</div>
            }
            @foreach (var u in Model.QuickList)
            {
                var on = e?.Id == u.Id;
                <a href="?id=@u.Id&keyword=@Uri.EscapeDataString(Model.Keyword ?? "")"
                   class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(on ? "active" : "")">
                    <span class="text-truncate">
                        @u.RealName
                        <span class="small @(on ? "text-white-50" : "text-muted")">（@u.EmployeeNo）</span>
                    </span>
                    @if (!u.IsActive)
                    {
                        <span class="badge @(on ? "bg-light text-dark" : "bg-secondary") flex-shrink-0">停用</span>
                    }
                </a>
            }
        </div>
    </div>

    <!-- ── 右侧：整合资料 ──────────────────────────────────────────────── -->
    <div class="flex-grow-1" style="min-width:0">
        @if (e is null)
        {
            <div class="card"><div class="card-body empty-state"><i class="bi bi-inbox"></i>未找到员工（系统里可能还没有员工，或者搜索没有匹配的人）</div></div>
        }
        else
        {
            <div class="card mb-3">
                <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div>
                        <h4 class="mb-1">
                            @e.RealName
                            <span class="badge bg-secondary align-middle">@e.Role.ToDisplayName()</span>
                            @if (e.Role == UserRole.Admin)
                            { <span class="badge bg-primary align-middle">正式工</span> }
                            else
                            { <span class="badge bg-light text-muted align-middle">临时工</span> }
                        </h4>
                        <div class="text-muted small">工号 @e.EmployeeNo</div>
                    </div>
                    <div>
                        @switch (e.Status)
                        {
                            case EmployeeStatus.Active:      <span class="badge bg-success fs-6">在职</span>    break;
                            case EmployeeStatus.Disabled:    <span class="badge bg-secondary fs-6">已停用</span> break;
                            case EmployeeStatus.Blacklisted: <span class="badge bg-dark fs-6">黑名单</span>     break;
                        }
                    </div>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-header"><i class="bi bi-diagram-3 me-1 text-primary"></i>组织信息</div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-5">所属部门</dt><dd class="col-7">@(e.Department?.DeptName ?? "未分配")</dd>
                                <dt class="col-5">考勤组</dt><dd class="col-7">@(e.AttendanceGroup?.GroupName ?? "未分配")</dd>
                                <dt class="col-5">直属上级</dt><dd class="col-7">@(e.Supervisor?.RealName ?? "无")</dd>
                                <dt class="col-5">岗位</dt><dd class="col-7">@(e.Position ?? "—")</dd>
                            </dl>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-header"><i class="bi bi-telephone me-1 text-primary"></i>联系方式</div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-5">手机号</dt><dd class="col-7">@(e.Phone ?? "—")</dd>
                                <dt class="col-5">家庭住址</dt><dd class="col-7">@(e.HomeAddress ?? "—")</dd>
                            </dl>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-header"><i class="bi bi-person-badge me-1 text-primary"></i>证件信息</div>
                        <div class="card-body">
                            <dl class="row mb-2">
                                <dt class="col-5">身份证号</dt><dd class="col-7">@(e.IdNumber ?? "—")</dd>
                            </dl>
                            @if (!string.IsNullOrEmpty(e.IdCardPhotoUrl))
                            {
                                <a href="@e.IdCardPhotoUrl" target="_blank">
                                    <img src="@e.IdCardPhotoUrl" alt="身份证照片" class="border rounded"
                                         style="max-width:100%;max-height:180px" />
                                </a>
                            }
                            else
                            {
                                <div class="text-muted small">未上传身份证照片</div>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-header"><i class="bi bi-person-exclamation me-1 text-primary"></i>紧急联系人</div>
                        <div class="card-body">
                            @if (string.IsNullOrEmpty(e.EmergencyContactName) && string.IsNullOrEmpty(e.EmergencyContactPhone))
                            {
                                <div class="text-muted small">未登记紧急联系人</div>
                            }
                            else
                            {
                                <dl class="row mb-0">
                                    <dt class="col-5">姓名</dt><dd class="col-7">@(e.EmergencyContactName ?? "—")</dd>
                                    <dt class="col-5">电话</dt><dd class="col-7">@(e.EmergencyContactPhone ?? "—")</dd>
                                </dl>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-header"><i class="bi bi-briefcase me-1 text-primary"></i>合同 / 入职信息</div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-5">合同公司</dt><dd class="col-7">@(e.ContractCompany ?? "—")</dd>
                                <dt class="col-5">入职日期</dt><dd class="col-7">@(e.HireDate?.ToString("yyyy-MM-dd") ?? "—")</dd>
                            </dl>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-header"><i class="bi bi-gear me-1 text-primary"></i>账号信息</div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-5">钉钉绑定</dt>
                                <dd class="col-7">
                                    @if (!string.IsNullOrEmpty(e.DingTalkUserId))
                                    { <span class="text-primary"><i class="bi bi-link-45deg"></i> 已绑定</span> }
                                    else
                                    { <span class="text-muted"><i class="bi bi-slash-circle"></i> 未绑定</span> }
                                </dd>
                                <dt class="col-5">创建时间</dt><dd class="col-7">@e.CreatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
                                <dt class="col-5">最近修改</dt><dd class="col-7">@e.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</dd>
                                <dt class="col-5">最近登录</dt><dd class="col-7">@(e.LastLoginAt?.ToString("yyyy-MM-dd HH:mm") ?? "从未登录")</dd>
                            </dl>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
