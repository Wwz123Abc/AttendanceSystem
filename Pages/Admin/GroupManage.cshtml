@page
@model AttendanceSystem.Pages.Admin.GroupManageModel
@{ ViewData["Title"] = "考勤组管理"; }

<div class="page-header d-flex justify-content-between align-items-center">
    <h4><i class="bi bi-building me-2 text-primary"></i>考勤组管理</h4>
    <div class="d-flex gap-2">
        <form method="post" asp-page-handler="SyncDeptGroups" class="mb-0"
              onsubmit="return confirm('将按部门自动补建考勤组，并把每位有部门的员工归入其部门对应的考勤组（考勤组跟随部门）。确认执行？')">
            <button type="submit" class="btn btn-outline-primary btn-sm" title="给每个部门建好考勤组，并让员工考勤组跟随部门">
                <i class="bi bi-arrow-repeat me-1"></i>按部门同步
            </button>
        </form>
        <button class="btn btn-primary btn-sm" onclick="openAdd()">
            <i class="bi bi-plus-lg me-1"></i>新建考勤组
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-x-circle me-2"></i>@Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>考勤组名称</th>
                    <th>所属公司</th>
                    <th>人员数</th>
                    <th>定位打卡</th>
                    <th>午休/晚餐</th>
                    <th>状态</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (g, cnt) in Model.Groups)
                {
                    <tr>
                        <td class="fw-semibold">@g.GroupName</td>
                        <td>@(g.CompanyName ?? "-")</td>
                        <td><span class="badge bg-secondary">@cnt 人</span></td>
                        <td>
                            @if (g.EnableLocationPunch)
                            {
                                <span class="badge bg-success">已启用<br/><small>@(g.LocationName ?? "未命名")</small></span>
                            }
                            else
                            {
                                <span class="text-muted small">未启用</span>
                            }
                        </td>
                        <td class="small">午休 @g.LunchBreakMinutes 分钟 / 晚餐 @g.DinnerBreakMinutes 分钟</td>
                        <td>
                            @if (g.IsActive)
                            { <span class="badge bg-success">启用</span> }
                            else
                            { <span class="badge bg-secondary">停用</span> }
                        </td>
                        <td>
                            <button class="btn btn-outline-primary btn-sm"
                                    onclick="openEdit(@g.Id,'@g.GroupName.Replace("'","\\'")',
                                             '@(g.CompanyName ?? "")',@g.PunchRadiusMeters,
                                             @(g.LocationLatitude?.ToString() ?? "null"),
                                             @(g.LocationLongitude?.ToString() ?? "null"),
                                             '@(g.LocationName ?? "")',
                                             @(g.EnableLocationPunch ? "true" : "false"),
                                             @g.LunchBreakMinutes,@g.DinnerBreakMinutes)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <form method="post" asp-page-handler="Toggle" class="d-inline"
                                  onsubmit="return confirm('@(g.IsActive ? "确认停用该考勤组？" : "确认启用该考勤组？")')">
                                <input type="hidden" name="id" value="@g.Id" />
                                <button type="submit" class="btn btn-sm @(g.IsActive ? "btn-outline-warning" : "btn-outline-success")">
                                    <i class="bi bi-@(g.IsActive ? "pause" : "play")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Groups.Any())
                {
                    <tr><td colspan="7" class="empty-state"><i class="bi bi-inbox"></i>暂无考勤组</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- 新建/编辑 Modal -->
<div class="modal fade" id="groupModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" asp-page-handler="Save">
                <input type="hidden" asp-for="EditId" id="editId" />
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle">新建考勤组</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">考勤组名称 <span class="text-danger">*</span></label>
                            <input asp-for="GroupName" id="fGroupName" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">所属公司</label>
                            <input asp-for="CompanyName" id="fCompany" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">午休时长（分钟）</label>
                            <input asp-for="LunchBreak" id="fLunch" type="number" min="0" max="120" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">晚餐时长（分钟）</label>
                            <input asp-for="DinnerBreak" id="fDinner" type="number" min="0" max="120" class="form-control" />
                        </div>
                        <div class="col-12">
                            <hr class="my-1" />
                            <div class="form-check form-switch">
                                <input asp-for="EnableLocation" id="fEnableLocation" class="form-check-input" type="checkbox"
                                       onchange="toggleLocation(this.checked)" />
                                <label class="form-check-label fw-semibold" for="EnableLocation">启用定位打卡</label>
                            </div>
                        </div>
                        <div id="locationFields">
                            <div class="row g-3">
                                <div class="col-md-12">
                                    <label class="form-label fw-semibold">打卡地点名称</label>
                                    <input asp-for="LocationName" id="fLocName" class="form-control" placeholder="如：总公司大楼" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">纬度</label>
                                    <input asp-for="Latitude" id="fLat" type="number" step="0.000001" class="form-control" placeholder="如：22.543096" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">经度</label>
                                    <input asp-for="Longitude" id="fLng" type="number" step="0.000001" class="form-control" placeholder="如：114.057865" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">有效半径（米）</label>
                                    <input asp-for="PunchRadius" id="fRadius" type="number" min="50" max="5000" class="form-control" />
                                </div>
                                <div class="col-12">
                                    <button type="button" class="btn btn-outline-secondary btn-sm" onclick="getMyLocation()">
                                        <i class="bi bi-geo-alt me-1"></i>获取当前位置
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                    <button type="submit" class="btn btn-primary">保存</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
const modal = new bootstrap.Modal(document.getElementById('groupModal'));

function openAdd() {
    document.getElementById('modalTitle').textContent = '新建考勤组';
    document.getElementById('editId').value = 0;
    document.getElementById('fGroupName').value = '';
    document.getElementById('fCompany').value = '';
    document.getElementById('fLunch').value = 60;
    document.getElementById('fDinner').value = 30;
    document.getElementById('fEnableLocation').checked = false;
    document.getElementById('fLocName').value = '';
    document.getElementById('fLat').value = '';
    document.getElementById('fLng').value = '';
    document.getElementById('fRadius').value = 500;
    toggleLocation(false);
    modal.show();
}

function openEdit(id, name, company, radius, lat, lng, locName, enableLoc, lunch, dinner) {
    document.getElementById('modalTitle').textContent = '编辑考勤组';
    document.getElementById('editId').value = id;
    document.getElementById('fGroupName').value = name;
    document.getElementById('fCompany').value = company;
    document.getElementById('fLunch').value = lunch;
    document.getElementById('fDinner').value = dinner;
    document.getElementById('fEnableLocation').checked = enableLoc;
    document.getElementById('fLocName').value = locName;
    document.getElementById('fLat').value = lat ?? '';
    document.getElementById('fLng').value = lng ?? '';
    document.getElementById('fRadius').value = radius;
    toggleLocation(enableLoc);
    modal.show();
}

// "是否启用定位打卡"这个开关：勾上才需要填打卡点的经纬度/半径，所以没勾的时候把这几个字段都藏起来
function toggleLocation(enabled) {
    document.getElementById('locationFields').style.display = enabled ? 'block' : 'none';
}

// "获取我的位置"按钮：直接用管理员当前所在的浏览器定位，自动填进经纬度框，
// 不用自己去查打卡点的经纬度是多少（常见用法：管理员站在打卡点现场点一下这个按钮）
function getMyLocation() {
    if (!navigator.geolocation) { alert('浏览器不支持定位'); return; }
    navigator.geolocation.getCurrentPosition(pos => {
        document.getElementById('fLat').value = pos.coords.latitude.toFixed(6);
        document.getElementById('fLng').value = pos.coords.longitude.toFixed(6);
    }, () => alert('获取位置失败，请手动输入'));
}

// 页面刚打开时，也要按当前"是否启用定位打卡"复选框的勾选状态，同步一次这几个字段的显示/隐藏
toggleLocation(document.getElementById('fEnableLocation')?.checked);
</script>
}
