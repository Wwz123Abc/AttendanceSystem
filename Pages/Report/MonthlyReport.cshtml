@page
@model AttendanceSystem.Pages.Report.MonthlyReportModel
@{
    ViewData["Title"] = "月度报表";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <h4><i class="bi bi-file-earmark-bar-graph me-2 text-primary"></i>月度考勤报表</h4>
</div>

<div class="card mb-4">
    <div class="card-body py-3">
        <form method="get" class="d-flex align-items-center gap-3 flex-wrap">
            <label class="fw-semibold mb-0">年份</label>
            <select name="year" class="form-select form-select-sm" style="width:100px">
                @for (int y = DateTime.Today.Year; y >= DateTime.Today.Year - 2; y--)
                {
                    <option value="@y" selected="@(y == Model.Year)">@y 年</option>
                }
            </select>
            <label class="fw-semibold mb-0">月份</label>
            <select name="month" class="form-select form-select-sm" style="width:90px">
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m" selected="@(m == Model.Month)">@m 月</option>
                }
            </select>
            <button type="submit" class="btn btn-primary btn-sm">
                <i class="bi bi-search me-1"></i>查询
            </button>
        </form>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header"><i class="bi bi-file-earmark-spreadsheet me-1"></i>模板格式月度汇总表（按公司要求的模板导出，含每日打卡明细）</div>
    <div class="card-body py-3">
        <form method="get" asp-page-handler="ExportTemplate">
            @* GET 表单提交时，浏览器只会保留表单里的字段拼成新的查询字符串，action 地址里 asp-page-handler
               生成的 "?handler=ExportTemplate" 会被整个丢弃——所以必须再放一个同名的隐藏字段，
               "handler" 这个值才能真正跟着提交上去，不然点了按钮会悄悄回到默认的 OnGetAsync（看起来就像没反应）。 *@
            <input type="hidden" name="handler" value="ExportTemplate" />
            <input type="hidden" name="year" value="@Model.Year" />
            <input type="hidden" name="month" value="@Model.Month" />
            <div class="mb-2 small text-muted">
                统计周期：@(Model.Month == 1 ? Model.Year - 1 : Model.Year)年@(Model.Month == 1 ? 12 : Model.Month - 1)月26日 至 @(Model.Year)年@(Model.Month)月25日（用上面选的"年份/月份"决定周期）
            </div>
            <label class="form-label fw-semibold mb-1">
                导出范围
                <small class="text-muted fw-normal">（勾选公司=连它下面所有部门一起导出，范围大；只勾具体部门=只导出这个部门，范围小；都不勾=导出全公司所有人）</small>
            </label>
            <div id="reportDeptTree" class="border rounded p-2 mb-2" style="max-height:240px;overflow-y:auto;">
                @foreach (var d in Model.DeptTree)
                {
                    <div class="form-check" style="padding-left:@(1.5 + d.Depth * 1.2)rem">
                        @if (d.RealDeptId.HasValue)
                        {
                            <input class="form-check-input dept-checkbox" type="checkbox"
                                   name="deptIds" value="@d.RealDeptId" id="rdept_@d.NodeId"
                                   data-id="@d.NodeId" data-parent="@d.ParentNodeId"
                                   onchange="onReportDeptCheckboxChange(this)" />
                            <label class="form-check-label" for="rdept_@d.NodeId">@d.Name</label>
                        }
                        else
                        {
                            <input class="form-check-input dept-checkbox" type="checkbox" id="rdept_@d.NodeId"
                                   data-id="@d.NodeId" data-parent=""
                                   onchange="onReportDeptCheckboxChange(this)" />
                            <label class="form-check-label fw-bold" for="rdept_@d.NodeId"><i class="bi bi-building me-1"></i>@d.Name</label>
                        }
                    </div>
                }
                @if (!Model.DeptTree.Any())
                {
                    <div class="text-muted small">暂无部门，请先到"部门管理"创建部门</div>
                }
            </div>
            <button type="submit" class="btn btn-success btn-sm">
                <i class="bi bi-download me-1"></i>导出模板汇总表
            </button>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">
        @Model.Year 年 @Model.Month 月 部门考勤汇总（共 @Model.Summaries.Count 人）
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>工号</th>
                        <th>姓名</th>
                        <th>部门</th>
                        <th>应出勤</th>
                        <th>实出勤</th>
                        <th>夜班</th>
                        <th>迟到</th>
                        <th>早退</th>
                        <th>缺勤</th>
                        <th>请假(天)</th>
                        <th>加班(h)</th>
                        <th>总工时(h)</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Summaries.Any())
                    {
                        <tr><td colspan="13" class="empty-state"><i class="bi bi-inbox"></i>暂无数据</td></tr>
                    }
                    @foreach (var s in Model.Summaries)
                    {
                        <tr>
                            <td class="small text-muted">@s.EmployeeNo</td>
                            <td class="fw-semibold">@s.RealName</td>
                            <td class="small">@s.DeptName</td>
                            <td>@s.ExpectedWorkdays</td>
                            <td class="@(s.ActualWorkdays < s.ExpectedWorkdays ? "text-danger" : "text-success")">@s.ActualWorkdays</td>
                            <td class="@(s.NightShiftDays > 0 ? "text-info fw-semibold" : "text-muted")">@s.NightShiftDays</td>
                            <td class="@(s.LateCount > 0 ? "text-warning" : "")">@s.LateCount</td>
                            <td class="@(s.EarlyLeaveCount > 0 ? "text-warning" : "")">@s.EarlyLeaveCount</td>
                            <td class="@(s.AbsentDays > 0 ? "text-danger" : "")">@s.AbsentDays</td>
                            <td>@s.LeaveDays.ToString("F1")</td>
                            <td>@s.TotalOvertimeHours.ToString("F1")</td>
                            <td>@s.TotalWorkHours.ToString("F1")</td>
                            <td>
                                <a asp-page-handler="ExportDetail"
                                   asp-route-userId="@s.UserId"
                                   asp-route-year="@Model.Year"
                                   asp-route-month="@Model.Month"
                                   class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-download"></i> 明细
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 勾选/取消"公司/部门"合并树里的某一项时，连带把它所有下级节点（部门/子部门）也一起勾上/取消，
        // 勾公司节点就相当于把它下面所有部门都选中，范围可以很大；只勾具体部门，范围就很小。
        function onReportDeptCheckboxChange(checkbox) {
            const checked = checkbox.checked;
            const nodeId  = checkbox.dataset.id;
            document.querySelectorAll(`#reportDeptTree .dept-checkbox[data-parent="${nodeId}"]`).forEach(child => {
                child.checked = checked;
                onReportDeptCheckboxChange(child);   // 递归处理下一级
            });
        }
    </script>
}
