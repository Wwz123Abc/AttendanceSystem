@page
@model AttendanceSystem.Pages.Employee.SelfRegisterModel
@{ ViewData["Title"] = "新员工登记"; Layout = null; }

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>新员工登记 - 科瑞技术考勤管理系统</title>
    <link rel="icon" type="image/png" href="~/img/logo-icon.png" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body { background: #F2F4F7; min-height: 100vh; display: flex; align-items: center; }
    </style>
</head>
<body>
<div class="container">
    <div class="row justify-content-center">
        <div class="col-11 col-sm-8 col-md-5">
            <div class="text-center mb-3">
                <img src="~/img/logo-icon.png" alt="科瑞技术" style="width:48px;height:48px" />
                <h4 class="mt-2 mb-0">新员工登记</h4>
                <p class="text-muted small mb-0">请填写以下基础信息，提交后等待管理员确认</p>
            </div>

            <div class="card">
                <div class="card-body p-4">
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger"><i class="bi bi-x-circle me-2"></i>@Model.ErrorMessage</div>
                    }

                    @if (Model.Done)
                    {
                        <div class="text-center py-3">
                            <i class="bi bi-check-circle text-success" style="font-size:3rem"></i>
                            <p class="mt-3 mb-0 fw-semibold">提交成功！</p>
                            <p class="text-muted small">请等待管理员确认，确认后会为您正式建号，请留意入职通知。</p>
                        </div>
                    }
                    else
                    {
                        <form method="post">
                            <div class="mb-3">
                                <label class="form-label fw-semibold">姓名</label>
                                <input asp-for="RealName" class="form-control" placeholder="请输入真实姓名" required autofocus />
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-semibold">手机号</label>
                                <input asp-for="Phone" class="form-control" type="tel" maxlength="11"
                                       pattern="^1[3-9]\d{9}$" title="请输入正确格式的手机号（11 位中国大陆手机号）"
                                       placeholder="请输入手机号" required />
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-semibold">身份证号</label>
                                <input asp-for="IdNumber" class="form-control" maxlength="18"
                                       pattern="^\d{17}[\dXx]$" title="请输入正确格式的身份证号（18 位）"
                                       placeholder="请输入 18 位身份证号" required />
                            </div>
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-send me-2"></i>提交
                            </button>
                        </form>
                    }
                </div>
            </div>
            <p class="text-center text-muted small mt-3">© 2026 科瑞技术 · 版权所有</p>
        </div>
    </div>
</div>
</body>
</html>
