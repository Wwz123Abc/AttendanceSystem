@page
@model AttendanceSystem.Pages.Account.ForgotPasswordModel
@{ ViewData["Title"] = "找回密码"; }

<div class="row justify-content-center" style="margin-top:4vh">
    <div class="col-md-5">
        <div class="text-center mb-3">
            <img src="~/img/logo-icon.png" alt="科瑞技术" style="width:48px;height:48px" />
            <h4 class="mt-2 mb-0">找回密码</h4>
            <p class="text-muted small mb-0">通过钉钉工作通知接收验证码</p>
        </div>

        <div class="card">
            <div class="card-body p-4">
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger"><i class="bi bi-x-circle me-2"></i>@Model.ErrorMessage</div>
                }
                @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                {
                    <div class="alert alert-success"><i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage</div>
                }

                @if (Model.Done)
                {
                    <a href="/Login" class="btn btn-primary w-100">
                        <i class="bi bi-box-arrow-in-right me-2"></i>返回登录
                    </a>
                }
                else if (!Model.CodeSent)
                {
                    <!-- 第一步：工号 + 手机号 -->
                    <form method="post" asp-page-handler="SendCode">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">工号</label>
                            <input asp-for="EmployeeNo" class="form-control" placeholder="请输入工号" autofocus autocomplete="username" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">手机号</label>
                            <input asp-for="Phone" class="form-control" placeholder="请输入账号绑定的手机号" />
                            <div class="form-text">需和账号绑定的手机号一致；账号需已绑定钉钉才能收到验证码。</div>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-send me-2"></i>获取验证码
                        </button>
                    </form>
                }
                else
                {
                    <!-- 第二步：验证码 + 新密码 -->
                    <form method="post" asp-page-handler="Reset">
                        <input type="hidden" asp-for="EmployeeNo" />
                        <input type="hidden" asp-for="Phone" />
                        <div class="mb-3">
                            <label class="form-label fw-semibold">验证码</label>
                            <input asp-for="Code" class="form-control" placeholder="请输入 6 位验证码" maxlength="6" autofocus autocomplete="one-time-code" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">新密码</label>
                            <input asp-for="NewPassword" type="password" class="form-control" placeholder="至少 6 位" autocomplete="new-password" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-semibold">确认新密码</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="再次输入新密码" autocomplete="new-password" />
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-check-lg me-2"></i>重置密码
                        </button>
                    </form>
                    <form method="post" asp-page-handler="SendCode" class="text-center mt-3">
                        <input type="hidden" asp-for="EmployeeNo" />
                        <input type="hidden" asp-for="Phone" />
                        <button type="submit" class="btn btn-link btn-sm text-decoration-none">没收到？重新发送验证码</button>
                    </form>
                }
            </div>
        </div>

        @if (!Model.Done)
        {
            <div class="text-center mt-3">
                <a href="/Login" class="small text-muted text-decoration-none"><i class="bi bi-arrow-left me-1"></i>返回登录</a>
            </div>
        }
    </div>
</div>
