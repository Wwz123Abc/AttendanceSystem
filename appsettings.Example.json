{
  "ConnectionStrings": {
    "Default": "Server=localhost;Port=3306;Database=AttendanceDB;User=root;Password=你的数据库密码;CharSet=utf8mb4;AllowPublicKeyRetrieval=true;SslMode=None;"
  },
  "AppSettings": {
    "DefaultPassword": "123456",
    "TokenExpireHours": 8,
    "UploadPath": "uploads",
    "DefaultDailyWorkHours": 8
  },
  "AMap": {
    "JsApiKey": "",
    "SecurityJsCode": ""
  },
  "DingTalk": {
    "AppKey": "你的钉钉AppKey",
    "AppSecret": "你的钉钉AppSecret",
    "AgentId": "你的钉钉AgentId",
    "OldGatewayBase": "https://oapi.dingtalk.com",
    "NewGatewayBase": "https://api.dingtalk.com",
    "MaxDaysPerRequest": 7,
    "MaxUsersPerRequest": 50,
    "PageSize": 50,
    "EnableScheduledSync": false,
    "ScheduledSyncIntervalMinutes": 60,
    "ScheduledSyncLookbackDays": 1
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/attendance-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
